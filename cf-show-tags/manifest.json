{
  "manifest_version": 3,
  "name": "Codeforces Tag Toggle",
  "version": "1.2",
  "description": "Show or hide Codeforces problem tags on demand",
  "permissions": ["activeTab"],
  "host_permissions": ["https://codeforces.com/*"],
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/problemset/problem/*",
        "https://codeforces.com/contest/*/problem/*",
        "https://codeforces.com/gym/*/problem/*",
        "https://codeforces.com/group/*/contest/*/problem/*"
      ],
      "js": ["content.js"]
    }
  ]
}